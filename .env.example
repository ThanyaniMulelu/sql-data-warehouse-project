# =============================================================================
# Environment Variables — copy this file to .env before running docker compose
#
#   cp .env.example .env          # Linux / macOS / WSL
#   Copy-Item .env.example .env   # Windows PowerShell
# =============================================================================

# SQL Server
MSSQL_SA_PASSWORD=YourStrong!Passw0rd123
ACCEPT_EULA=Y
MSSQL_PID=Developer

# Airflow
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__WEBSERVER__SECRET_KEY=change_me_to_a_random_string_123

# Airflow Metadata DB (Postgres)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# Airflow admin user
_AIRFLOW_WWW_USER_CREATE=True
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Superset
SUPERSET_SECRET_KEY=superset_secret_key_change_me_in_production
